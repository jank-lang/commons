#!/usr/bin/env bash

# This script is used by CI to detect which packages to publish to Clojars.
#
# Detection is done based on scanning the commits included in a push. For
# each commit, we list the tags associated with that commit. Each tag corresponds
# to a package + version pair which needs publishing. For example, we may
# have a tag like `gl-sys/2026.06-2`, which says that the `gl-sys` package
# has been updated to version `2026.06-2`.
#
# In order to create these tags, use `bin/release` locally, which will update
# the package's version, create the tag, and push for you.

set -euo pipefail

previous="${1}"
current="${2}"

declare -a to_publish

for commit in $(git log --reverse --pretty=format:"%H" "${previous}..${current}");
do
  echo "> ${commit}"
  for tag in $(git tag --points-at "${commit}");
  do
    echo "  > ${tag}"
    to_publish+=("${tag}")
  done
done

echo
for package in "${to_publish[@]}";
do
  name="${package%/*}"
  version="${package#*/}"
  pushd "${name}" >/dev/null
    echo ":: Deploying ${name} with new version ${version}"
    lein deploy
  popd >/dev/null
done
