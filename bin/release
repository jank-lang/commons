#!/usr/bin/env bash

# This script updates package versions and creates release tags. It then
# pushes to main, to trigger the publish, which happens in CI.
#
# Usage:
# $ ./bin/release gl-sys glfw-sys

set -euo pipefail

# Creates a tag for a package, based on the version which is in the package's project.clj.
#
# $1 = package to tag
function tag
{
  local package version
  package="${1}"
  pushd "${package}" >/dev/null
    version="$(lein update-in :version pr -- version | cut -d '"' -f 2)"
    echo "Tagging ${package}/${version}"
    git tag "${package}/${version}"
  popd >/dev/null
}

# Returns the date portion of a version string. i.e. 2026.06
function calver
{
  date +"%Y.%m"
}

# Updates the project.clj for a package to contain an updated version. Versions are based
# on date and minor releases. If the current version is already on the same date, we increment
# the minor release. Otherwise, we use the latest date and start at minor release 1.
#
# $1 = package to update
function update_version
{
  local current_version current_version_date current_version_minor
  local new_version new_version_date new_version_minor
  pushd "${package}" >/dev/null
    current_version="$(lein update-in :version pr -- version | cut -d '"' -f 2)"
    current_version_date="${current_version%-*}"
    current_version_minor="${current_version#*-}"
    new_version_date="$(calver)"
    new_version_minor=1
    if [[ "${current_version_date}" == "${new_version_date}" ]];
    then
      new_version_minor=$((current_version_minor + 1))
    fi
    new_version="${new_version_date}-${new_version_minor}"
    echo "${package} :: ${current_version} -> ${new_version}"
    sed -i'' "s#org.jank-lang.commons/${package} \"${current_version}\"#org.jank-lang.commons/${package} \"${new_version}\"#" project.clj
  popd >/dev/null
}

# First, update package project.clj files to have new versions.
# We keep the full output of the changes in `details` so we can
# provide it in the commit body.
details=""
for package in "${@}";
do
  details+="$(update_version "${package}")"$'\n'
  git add "${package}/project.clj"
done

echo "Showing diff before committing"
git diff

while true;
do
  read -r -p "Continue (y/n)? " should_continue
  case "${should_continue}"
  in
    y|Y)
      break
      ;;
    n|N)
      exit 1
      ;;
    *)
      echo "Invalid input."
      ;;
  esac
done

# We need to commit first, then tag.
git commit -m "Release ${*}" -m "${details}"

# Now that we have the commit, create a tag for each package.
for package in "${@}";
do
  tag "${package}"
done

# Push so we can trigger CI to run the publish script.
git push origin main --tags
