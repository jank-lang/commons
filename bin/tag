#!/usr/bin/env bash

# This script crates release tags for all specified packages.
# If the tag exists already, it will be updated.
#
# Usage:
# $ ./bin/tag gl-sys glfw-sys
#
# After creating the tags, you can then (force) push to trigger CI to catch
# them.
# $ git push origin main --tags -f

set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

pushd "${here}/.." >/dev/null
  for package in "${@}";
  do
    pushd "${package}" >/dev/null
      version="$(lein update-in :version pr -- version | cut -d '"' -f 2)"
      git tag -f "${package}/${version}"
    popd >/dev/null
  done
popd >/dev/null
